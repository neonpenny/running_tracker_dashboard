function fmtDate(d){const dt=new Date(d+'T12:00:00');return dt.toLocaleDateString('en-US',{month:'short',day:'numeric'});}
function fmtFull(d){const dt=new Date(d+'T12:00:00');return dt.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});}
function pStr(p){const m=Math.floor(p),s=Math.round((p-m)*60);return `${m}'${String(s).padStart(2,'0')}"'`;}

function renderStats(){
  const totalDist=runs.reduce((s,r)=>s+r.dist,0).toFixed(1);
  const totalCal=runs.reduce((s,r)=>s+r.cal,0);
  const avgHR=Math.round(runs.reduce((s,r)=>s+r.hr,0)/runs.length);
  const best=runs.reduce((b,r)=>r.paceMin<b.paceMin?r:b);
  const avgP=(runs.reduce((s,r)=>s+r.paceMin,0)/runs.length);
  const longest=runs.reduce((b,r)=>r.dist>b.dist?r:b);
  const pm=Math.floor(avgP),ps=Math.round((avgP-pm)*60);
  document.getElementById('stat-grid').innerHTML=`
    <div class="stat-card green"><div class="stat-label">Total Distance</div><div class="stat-value">${totalDist}</div><div class="stat-sub">miles · ${runs.length} runs</div></div>
    <div class="stat-card orange"><div class="stat-label">Total Calories</div><div class="stat-value">${totalCal.toLocaleString()}</div><div class="stat-sub">active calories burned</div></div>
    <div class="stat-card blue"><div class="stat-label">Avg Heart Rate</div><div class="stat-value">${avgHR}</div><div class="stat-sub">bpm average</div></div>
    <div class="stat-card green"><div class="stat-label">Best Pace</div><div class="stat-value" style="font-size:24px">${best.pace}/mi</div><div class="stat-sub">${fmtDate(best.date)}</div></div>
    <div class="stat-card blue"><div class="stat-label">Avg Pace</div><div class="stat-value" style="font-size:24px">${pm}'${String(ps).padStart(2,'0')}"/mi</div><div class="stat-sub">per mile</div></div>
    <div class="stat-card orange"><div class="stat-label">Longest Run</div><div class="stat-value">${longest.dist}</div><div class="stat-sub">mi · ${fmtDate(longest.date)}</div></div>
  `;
  document.getElementById('run-count').textContent=runs.length;
}

function renderTable(){
  const s=[...runs].sort((a,b)=>new Date(b.date)-new Date(a.date));
  document.getElementById('run-table').innerHTML=s.map(r=>`<tr>
    <td>${fmtFull(r.date)}</td><td>${r.dist}</td><td>${r.time}</td>
    <td class="${r.paceMin<11?'pace-fast':r.paceMin>14?'pace-slow':''}">${r.pace}</td>
    <td>${r.hr||'—'}</td><td>${r.cal}</td><td>${r.cad||'—'}</td>
    <td><span class="pill ${r.effort.toLowerCase()}">${r.effort}</span></td>
  </tr>`).join('');
}

const s=[...runs].sort((a,b)=>new Date(a.date)-new Date(b.date));
const labels=s.map(r=>fmtDate(r.date));
const opts={responsive:true,maintainAspectRatio:false,
  plugins:{legend:{display:false},tooltip:{backgroundColor:'#12121a',borderColor:'#1e1e2e',borderWidth:1,titleColor:'#5a5a7a',bodyColor:'#e8e8f0',titleFont:{family:'DM Mono',size:10},bodyFont:{family:'DM Mono',size:12}}},
  scales:{x:{grid:{color:'#1e1e2e'},ticks:{color:'#5a5a7a',font:{family:'DM Mono',size:9},maxRotation:60,maxTicksLimit:27}},
          y:{grid:{color:'#1e1e2e'},ticks:{color:'#5a5a7a',font:{family:'DM Mono',size:10}}}}};

new Chart(document.getElementById('distChart'),{type:'bar',data:{labels,datasets:[{data:s.map(r=>r.dist),backgroundColor:s.map(r=>r.dist>=3?'rgba(0,255,136,.75)':r.dist>=2?'rgba(0,255,136,.45)':'rgba(0,255,136,.25)'),borderColor:'rgba(0,255,136,.7)',borderWidth:1,borderRadius:3}]},options:opts});
new Chart(document.getElementById('paceChart'),{type:'line',data:{labels,datasets:[{data:s.map(r=>r.paceMin),borderColor:'#ff6b35',backgroundColor:'rgba(255,107,53,.08)',tension:.3,fill:true,pointBackgroundColor:'#ff6b35',pointRadius:2,pointHoverRadius:5}]},options:{...opts,scales:{...opts.scales,y:{...opts.scales.y,reverse:true}}}});
new Chart(document.getElementById('hrChart'),{type:'line',data:{labels,datasets:[{data:s.map(r=>r.hr),borderColor:'#4d9fff',backgroundColor:'rgba(77,159,255,.08)',tension:.3,fill:true,pointBackgroundColor:'#4d9fff',pointRadius:2,pointHoverRadius:5}]},options:opts});
new Chart(document.getElementById('calChart'),{type:'bar',data:{labels,datasets:[{data:s.map(r=>r.cal),backgroundColor:'rgba(255,107,53,.4)',borderColor:'#ff6b35',borderWidth:1,borderRadius:3}]},options:opts});
new Chart(document.getElementById('cadChart'),{type:'line',data:{labels,datasets:[{data:s.map(r=>r.cad||null),borderColor:'#00ff88',backgroundColor:'rgba(0,255,136,.06)',tension:.3,fill:true,pointBackgroundColor:'#00ff88',pointRadius:2,pointHoverRadius:5,spanGaps:true}]},options:opts});

function parsePace(s){const m=s.match(/(\d+)[':'](\d+)/);return m?parseInt(m[1])+parseInt(m[2])/60:10;}
function addRun(){
  const date=document.getElementById('f-date').value,dist=parseFloat(document.getElementById('f-dist').value),time=document.getElementById('f-time').value,pace=document.getElementById('f-pace').value,hr=parseInt(document.getElementById('f-hr').value)||0,cal=parseInt(document.getElementById('f-cal').value)||0,cad=parseInt(document.getElementById('f-cad').value)||0,effort=document.getElementById('f-effort').value;
  if(!date||isNaN(dist)||!pace){alert('Fill in date, distance, and pace.');return;}
  runs.push({date,dist,time:time||'',pace,paceMin:parsePace(pace),hr,cal,cad,effort});
  document.getElementById('success-msg').style.display='inline';
  setTimeout(()=>document.getElementById('success-msg').style.display='none',2500);
  ['f-date','f-dist','f-time','f-pace','f-hr','f-cal','f-cad'].forEach(id=>document.getElementById(id).value='');
  renderStats();renderTable();
}
renderStats();renderTable();
</script>
</body>
</html>