const fmtDate = d => {
  const dt = new Date(d + 'T12:00:00');
  return dt.toLocaleDateString('en-US', { month:'short', day:'numeric' });
};
const fmtFull = d => {
  const dt = new Date(d + 'T12:00:00');
  return dt.toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' });
};

const EFFORT_COLOR = { Hard:'#ff6b35', Moderate:'#4d9fff', 'All Out':'#ff0080', Easy:'#00ff88' };

const CustomTooltip = ({ active, payload, label, unit }) => {
  if (!active || !payload?.length) return null;
  return (
    <div style={{ background:'#12121a', border:'1px solid #1e1e2e', borderRadius:8, padding:'8px 12px', fontFamily:'monospace', fontSize:12 }}>
      <div style={{ color:'#5a5a7a', marginBottom:4 }}>{label}</div>
      <div style={{ color:'#e8e8f0', fontWeight:600 }}>{payload[0].value}{unit}</div>
    </div>
  );
};

export default function RunTracker() {
  const [runs, setRuns] = useState(ALL_RUNS);
  const [activeTab, setActiveTab] = useState('charts');
  const [form, setForm] = useState({ date:'', dist:'', time:'', pace:'', hr:'', cal:'', cad:'', effort:'Moderate' });

  const sorted = useMemo(() => [...runs].sort((a,b) => new Date(a.date) - new Date(b.date)), [runs]);
  const tableRuns = useMemo(() => [...runs].sort((a,b) => new Date(b.date) - new Date(a.date)), [runs]);

  const stats = useMemo(() => {
    const totalDist = runs.reduce((s,r) => s + r.dist, 0);
    const totalCal = runs.reduce((s,r) => s + r.cal, 0);
    const avgHR = Math.round(runs.reduce((s,r) => s + r.hr, 0) / runs.length);
    const best = runs.reduce((b,r) => r.paceMin < b.paceMin ? r : b);
    const avgP = runs.reduce((s,r) => s + r.paceMin, 0) / runs.length;
    const longest = runs.reduce((b,r) => r.dist > b.dist ? r : b);
    const pm = Math.floor(avgP), ps = Math.round((avgP - pm) * 60);
    return { totalDist: totalDist.toFixed(1), totalCal, avgHR, best, avgPaceStr: `${pm}'${String(ps).padStart(2,'0')}"`, longest };
  }, [runs]);

  const chartData = sorted.map((r, i) => ({ ...r, label: fmtDate(r.date), index: i }));

  const addRun = () => {
    if (!form.date || !form.dist || !form.pace) return;
    const m = form.pace.match(/(\d+)[':'](\d+)/);
    const paceMin = m ? parseInt(m[1]) + parseInt(m[2]) / 60 : 12;
    setRuns(prev => [...prev, { ...form, dist: parseFloat(form.dist), hr: parseInt(form.hr)||0, cal: parseInt(form.cal)||0, cad: parseInt(form.cad)||0, paceMin }]);
    setForm({ date:'', dist:'', time:'', pace:'', hr:'', cal:'', cad:'', effort:'Moderate' });
  };

  const StatCard = ({ label, value, sub, color }) => (
    <div style={{ background:'#12121a', border:'1px solid #1e1e2e', borderRadius:12, padding:'18px 16px', position:'relative', overflow:'hidden' }}>
      <div style={{ position:'absolute', top:0, left:0, right:0, height:2, background:color }} />
      <div style={{ fontFamily:'monospace', fontSize:10, letterSpacing:2, color:'#5a5a7a', textTransform:'uppercase', marginBottom:8 }}>{label}</div>
      <div style={{ fontFamily:'monospace', fontSize:28, fontWeight:700, color, lineHeight:1 }}>{value}</div>
      <div style={{ fontSize:11, color:'#5a5a7a', marginTop:4 }}>{sub}</div>
    </div>
  );

  return (
    <div style={{ background:'#0a0a0f', minHeight:'100vh', color:'#e8e8f0', fontFamily:'sans-serif', padding:'24px 20px' }}>
      {/* Header */}
      <div style={{ display:'flex', justifyContent:'space-between', alignItems:'flex-end', marginBottom:32, borderBottom:'1px solid #1e1e2e', paddingBottom:20 }}>
        <div>
          <div style={{ fontFamily:'monospace', fontSize:42, fontWeight:900, letterSpacing:4, lineHeight:.9, background:'linear-gradient(135deg,#00ff88,#4d9fff)', WebkitBackgroundClip:'text', WebkitTextFillColor:'transparent' }}>RUN<br/>TRACKER</div>
        </div>
        <div style={{ textAlign:'right', fontFamily:'monospace', fontSize:12, color:'#5a5a7a' }}>
          <div>ALL RUNS LOADED</div>
          <div style={{ color:'#00ff88', fontSize:24, fontWeight:700 }}>{runs.length}</div>
          <div>RUNS · NOV 2024–MAR 2025</div>
        </div>
      </div>

      {/* Stats */}
      <div style={{ display:'grid', gridTemplateColumns:'repeat(auto-fit,minmax(150px,1fr))', gap:10, marginBottom:28 }}>
        <StatCard label="Total Distance" value={`${stats.totalDist} mi`} sub={`${runs.length} runs`} color="#00ff88" />
        <StatCard label="Total Calories" value={stats.totalCal.toLocaleString()} sub="active cal burned" color="#ff6b35" />
        <StatCard label="Avg Heart Rate" value={`${stats.avgHR} bpm`} sub="average" color="#4d9fff" />
        <StatCard label="Best Pace" value={stats.best.pace} sub={fmtDate(stats.best.date)} color="#00ff88" />
        <StatCard label="Avg Pace" value={stats.avgPaceStr+"/mi"} sub="per mile" color="#4d9fff" />
        <StatCard label="Longest Run" value={`${stats.longest.dist} mi`} sub={fmtDate(stats.longest.date)} color="#ff6b35" />
      </div>

      {/* Tabs */}
      <div style={{ display:'flex', gap:8, marginBottom:20 }}>
        {['charts','table','log'].map(t => (
          <button key={t} onClick={() => setActiveTab(t)} style={{ background: activeTab===t ? '#00ff88' : '#12121a', color: activeTab===t ? '#0a0a0f' : '#5a5a7a', border:'1px solid ' + (activeTab===t ? '#00ff88' : '#1e1e2e'), borderRadius:6, padding:'7px 18px', fontFamily:'monospace', fontSize:11, letterSpacing:2, textTransform:'uppercase', cursor:'pointer', fontWeight: activeTab===t ? 700 : 400 }}>
            {t}
          </button>
        ))}
      </div>

      {/* Charts Tab */}
      {activeTab === 'charts' && (
        <div style={{ display:'flex', flexDirection:'column', gap:16 }}>
          {/* Distance */}
          <div style={{ background:'#12121a', border:'1px solid #1e1e2e', borderRadius:12, padding:20 }}>
            <div style={{ fontFamily:'monospace', fontSize:10, letterSpacing:2, color:'#5a5a7a', textTransform:'uppercase', marginBottom:16 }}>— Distance Per Run (mi)</div>
            <ResponsiveContainer width="100%" height={200}>
              <BarChart data={chartData} margin={{ left:-20 }}>
                <XAxis dataKey="label" tick={{ fill:'#5a5a7a', fontSize:9, fontFamily:'monospace' }} tickLine={false} axisLine={false} interval={6} />
                <YAxis tick={{ fill:'#5a5a7a', fontSize:10, fontFamily:'monospace' }} tickLine={false} axisLine={false} />
                <Tooltip content={<CustomTooltip unit=" mi" />} />
                <ReferenceLine x={fmtDate("2025-03-15")} stroke="#00ff88" strokeDasharray="3 3" label={{ value:'🏁', position:'top', fill:'#00ff88', fontSize:14 }} />
                <Bar dataKey="dist" fill="#00ff88" opacity={0.6} radius={[2,2,0,0]}
                  label={false}
                  isAnimationActive={false} />
              </BarChart>
            </ResponsiveContainer>
          </div>

          <div style={{ display:'grid', gridTemplateColumns:'1fr 1fr', gap:16 }}>
            {/* Pace */}
            <div style={{ background:'#12121a', border:'1px solid #1e1e2e', borderRadius:12, padding:20 }}>
              <div style={{ fontFamily:'monospace', fontSize:10, letterSpacing:2, color:'#5a5a7a', textTransform:'uppercase', marginBottom:16 }}>— Avg Pace (lower = faster ↓)</div>
              <ResponsiveContainer width="100%" height={160}>
                <LineChart data={chartData} margin={{ left:-20 }}>
                  <XAxis dataKey="label" tick={{ fill:'#5a5a7a', fontSize:8, fontFamily:'monospace' }} tickLine={false} axisLine={false} interval={9} />
                  <YAxis reversed tick={{ fill:'#5a5a7a', fontSize:9, fontFamily:'monospace' }} tickLine={false} axisLine={false} domain={['auto','auto']} />
                  <Tooltip content={<CustomTooltip unit=" min/mi" />} />
                  <Line dataKey="paceMin" stroke="#ff6b35" strokeWidth={2} dot={false} isAnimationActive={false} />
                </LineChart>
              </ResponsiveContainer>
            </div>

            {/* HR */}
            <div style={{ background:'#12121a', border:'1px solid #1e1e2e', borderRadius:12, padding:20 }}>
              <div style={{ fontFamily:'monospace', fontSize:10, letterSpacing:2, color:'#5a5a7a', textTransform:'uppercase', marginBottom:16 }}>— Avg Heart Rate (bpm)</div>
              <ResponsiveContainer width="100%" height={160}>
                <LineChart data={chartData} margin={{ left:-20 }}>
                  <XAxis dataKey="label" tick={{ fill:'#5a5a7a', fontSize:8, fontFamily:'monospace' }} tickLine={false} axisLine={false} interval={9} />
                  <YAxis tick={{ fill:'#5a5a7a', fontSize:9, fontFamily:'monospace' }} tickLine={false} axisLine={false} domain={['auto','auto']} />
                  <Tooltip content={<CustomTooltip unit=" bpm" />} />
                  <Line dataKey="hr" stroke="#4d9fff" strokeWidth={2} dot={false} isAnimationActive={false} />
                </LineChart>
              </ResponsiveContainer>
            </div>

            {/* Cadence */}
            <div style={{ background:'#12121a', border:'1px solid #1e1e2e', borderRadius:12, padding:20 }}>
              <div style={{ fontFamily:'monospace', fontSize:10, letterSpacing:2, color:'#5a5a7a', textTransform:'uppercase', marginBottom:16 }}>— Avg Cadence (spm)</div>
              <ResponsiveContainer width="100%" height={160}>
                <LineChart data={chartData} margin={{ left:-20 }}>
                  <XAxis dataKey="label" tick={{ fill:'#5a5a7a', fontSize:8, fontFamily:'monospace' }} tickLine={false} axisLine={false} interval={9} />
                  <YAxis tick={{ fill:'#5a5a7a', fontSize:9, fontFamily:'monospace' }} tickLine={false} axisLine={false} domain={['auto','auto']} />
                  <Tooltip content={<CustomTooltip unit=" spm" />} />
                  <Line dataKey="cad" stroke="#00ff88" strokeWidth={2} dot={false} isAnimationActive={false} connectNulls />
                </LineChart>
              </ResponsiveContainer>
            </div>

            {/* Calories */}
            <div style={{ background:'#12121a', border:'1px solid #1e1e2e', borderRadius:12, padding:20 }}>
              <div style={{ fontFamily:'monospace', fontSize:10, letterSpacing:2, color:'#5a5a7a', textTransform:'uppercase', marginBottom:16 }}>— Active Calories</div>
              <ResponsiveContainer width="100%" height={160}>
                <BarChart data={chartData} margin={{ left:-20 }}>
                  <XAxis dataKey="label" tick={{ fill:'#5a5a7a', fontSize:8, fontFamily:'monospace' }} tickLine={false} axisLine={false} interval={9} />
                  <YAxis tick={{ fill:'#5a5a7a', fontSize:9, fontFamily:'monospace' }} tickLine={false} axisLine={false} />
                  <Tooltip content={<CustomTooltip unit=" cal" />} />
                  <Bar dataKey="cal" fill="#ff6b35" opacity={0.6} radius={[2,2,0,0]} isAnimationActive={false} />
                </BarChart>
              </ResponsiveContainer>
            </div>
          </div>
        </div>
      )}

      {/* Table Tab */}
      {activeTab === 'table' && (
        <div style={{ background:'#12121a', border:'1px solid #1e1e2e', borderRadius:12, overflow:'auto' }}>
          <table style={{ width:'100%', borderCollapse:'collapse', fontSize:12 }}>
            <thead>
              <tr style={{ borderBottom:'1px solid #1e1e2e' }}>
                {['Date','Dist','Time','Pace','HR','Cal','Cad','Effort'].map(h => (
                  <th key={h} style={{ fontFamily:'monospace', fontSize:10, letterSpacing:2, color:'#5a5a7a', textTransform:'uppercase', padding:'10px 12px', textAlign:'left', fontWeight:400 }}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {tableRuns.map((r, i) => (
                <tr key={i} style={{ borderBottom:'1px solid rgba(30,30,46,.5)', background: r.race ? 'rgba(0,255,136,.05)' : 'transparent' }}>
                  <td style={{ padding:'9px 12px', fontFamily:'monospace', fontSize:12 }}>{fmtFull(r.date)}{r.race && <span style={{ color:'#00ff88', marginLeft:6, fontSize:10 }}>🏁 5K</span>}</td>
                  <td style={{ padding:'9px 12px', fontFamily:'monospace', fontSize:12 }}>{r.dist}</td>
                  <td style={{ padding:'9px 12px', fontFamily:'monospace', fontSize:12 }}>{r.time}</td>
                  <td style={{ padding:'9px 12px', fontFamily:'monospace', fontSize:12, color: r.paceMin < 11 ? '#00ff88' : r.paceMin > 15 ? '#5a5a7a' : '#e8e8f0' }}>{r.pace}</td>
                  <td style={{ padding:'9px 12px', fontFamily:'monospace', fontSize:12 }}>{r.hr}</td>
                  <td style={{ padding:'9px 12px', fontFamily:'monospace', fontSize:12 }}>{r.cal}</td>
                  <td style={{ padding:'9px 12px', fontFamily:'monospace', fontSize:12 }}>{r.cad||'—'}</td>
                  <td style={{ padding:'9px 12px' }}>
                    <span style={{ background: EFFORT_COLOR[r.effort]+'22', color: EFFORT_COLOR[r.effort]||'#e8e8f0', padding:'2px 8px', borderRadius:20, fontSize:10, fontFamily:'monospace' }}>{r.effort}</span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      {/* Log Tab */}
      {activeTab === 'log' && (
        <div style={{ background:'#12121a', border:'1px solid #1e1e2e', borderRadius:12, padding:24 }}>
          <div style={{ fontFamily:'monospace', fontSize:20, fontWeight:700, color:'#00ff88', letterSpacing:2, marginBottom:20 }}>+ LOG NEW RUN</div>
          <div style={{ display:'grid', gridTemplateColumns:'repeat(auto-fill,minmax(160px,1fr))', gap:12, marginBottom:16 }}>
            {[
              { label:'Date', key:'date', type:'date' },
              { label:'Distance (mi)', key:'dist', type:'number', placeholder:'2.50' },
              { label:'Time', key:'time', type:'text', placeholder:'0:25:00' },
              { label:'Pace', key:'pace', type:'text', placeholder:"11'30\"" },
              { label:'Avg HR', key:'hr', type:'number', placeholder:'160' },
              { label:'Active Cal', key:'cal', type:'number', placeholder:'200' },
              { label:'Cadence', key:'cad', type:'number', placeholder:'165' },
            ].map(f => (
              <div key={f.key}>
                <div style={{ fontFamily:'monospace', fontSize:10, letterSpacing:2, color:'#5a5a7a', textTransform:'uppercase', marginBottom:6 }}>{f.label}</div>
                <input type={f.type} placeholder={f.placeholder} value={form[f.key]}
                  onChange={e => setForm(p => ({ ...p, [f.key]: e.target.value }))}
                  style={{ width:'100%', background:'#0a0a0f', border:'1px solid #1e1e2e', borderRadius:6, color:'#e8e8f0', padding:'8px 10px', fontFamily:'monospace', fontSize:13, outline:'none' }} />
              </div>
            ))}
            <div>
              <div style={{ fontFamily:'monospace', fontSize:10, letterSpacing:2, color:'#5a5a7a', textTransform:'uppercase', marginBottom:6 }}>Effort</div>
              <select value={form.effort} onChange={e => setForm(p => ({ ...p, effort: e.target.value }))}
                style={{ width:'100%', background:'#0a0a0f', border:'1px solid #1e1e2e', borderRadius:6, color:'#e8e8f0', padding:'8px 10px', fontFamily:'monospace', fontSize:13, outline:'none' }}>
                {['Moderate','Hard','Easy','All Out'].map(e => <option key={e}>{e}</option>)}
              </select>
            </div>
          </div>
          <button onClick={addRun} style={{ background:'#00ff88', color:'#0a0a0f', border:'none', borderRadius:6, padding:'10px 24px', fontFamily:'monospace', fontSize:12, letterSpacing:2, textTransform:'uppercase', cursor:'pointer', fontWeight:700 }}>
            Add Run
          </button>
        </div>
      )}
    </div>
  );
}