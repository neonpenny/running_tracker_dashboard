_DAV_NS = “DAV:”

def _tag(name: str) -> str:
return f”{{{_DAV_NS}}}{name}”

def _propfind(session: requests.Session, url: str) -> ET.Element:
“”“Issue a WebDAV PROPFIND depth=1 and return parsed XML.”””
headers = {
“Depth”: “1”,
“Content-Type”: “application/xml; charset=utf-8”,
}
body = (
‘<?xml version="1.0" encoding="utf-8"?>’
‘<D:propfind xmlns:D=“DAV:”><D:allprop/></D:propfind>’
)
resp = session.request(“PROPFIND”, url, headers=headers, data=body, timeout=30)

