# 6. RECURSIVE WALKER

# —————————————————————————

def walk_folder(
session:     requests.Session,
dav_base:    str,
folder_path: str,
depth:       int = 0,
) -> FolderNode:
“””
Recursively walk a WebDAV folder and return a populated FolderNode tree.

```
Parameters
----------
dav_base    : WebDAV root URL, e.g.
              "https://owncloud.polloanalytics.com/remote.php/dav/files/pryan"
folder_path : Decoded path relative to dav_base, e.g. "/Peter's Photos"
depth       : Current recursion depth (for indented console output)
"""
# Percent-encode each path segment individually (preserves slashes)
encoded_path = "/".join(
    quote(seg, safe="") for seg in folder_path.split("/")
)
url = dav_base.rstrip("/") + encoded_path

print("  " * depth + f"📂 Scanning: {folder_path}")

xml_root = _propfind(session, url)
entries  = _parse_multistatus(xml_root)

folder_name = folder_path.rstrip("/").split("/")[-1] or "root"
node = FolderNode(name=folder_name, path=folder_path)

for entry in entries:
    # Skip the folder itself (always the first entry at depth=1)
    if entry["decoded_path"].rstrip("/") == unquote(encoded_path).rstrip("/"):
        continue

    if entry["is_collection"]:
        child_path = folder_path.rstrip("/") + "/" + entry["name"]
        child_node = walk_folder(session, dav_base, child_path, depth + 1)
        node.folders.append(child_node)
        node.total_images     += child_node.total_images
        node.total_size_bytes += child_node.total_size_bytes
    else:
        ext = Path(entry["name"]).suffix.lower()
        if ext in IMAGE_EXTENSIONS:
            photo = PhotoFile(
                name          = entry["name"],
                path          = entry["decoded_path"],
                size_bytes    = entry["size"],
                last_modified = entry["last_modified"],
                extension     = ext,
                etag          = entry["etag"],
            )
            node.files.append(photo)
            node.total_images     += 1
            node.total_size_bytes += entry["size"]

return node
```

