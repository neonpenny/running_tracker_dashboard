# 7. REPORT WRITERS

# —————————————————————————

def _fmt_size(b: int) -> str:
for unit in (“B”, “KB”, “MB”, “GB”):
if b < 1024:
return f”{b:.1f} {unit}”
b /= 1024
return f”{b:.1f} TB”

def _tree_lines(node: FolderNode, indent: int = 0) -> list[str]:
pad     = “  “ * indent
summary = f”  [{node.total_images} images, {_fmt_size(node.total_size_bytes)}]”
lines   = [f”{pad}📂 {node.name}{summary}”]
for sub in node.folders:
lines.extend(_tree_lines(sub, indent + 1))
for img in node.files:
lines.append(
f”{’  ’ * (indent + 1)}🖼  {img.name}”
f”  ({_fmt_size(img.size_bytes)})  [{img.last_modified}]”
)
return lines

def write_text_report(root: FolderNode, dest: Path) -> None:
lines = [
“=” * 72,
“Peter J Ryan Photography – ownCloud Folder Report”,
f”Generated : {datetime.now().strftime(’%Y-%m-%d %H:%M:%S’)}”,
f”Root path : {root.path}”,
f”Total images : {root.total_images}”,
f”Total size   : {_fmt_size(root.total_size_bytes)}”,
“=” * 72,
“”,
“FOLDER TREE”,
“-” * 72,
]
lines.extend(_tree_lines(root))
lines += [
“”,
“-” * 72,
“TOP-LEVEL FOLDER SUMMARY”,
“-” * 72,
]
for folder in sorted(root.folders, key=lambda f: f.total_images, reverse=True):
lines.append(
f”  {folder.name:<40} {folder.total_images:>5} images”
f”   {_fmt_size(folder.total_size_bytes):>10}”
)
lines += [
“”,
“NEXT STEPS”,
“-” * 72,
“  1. Review this tree and note folders to EXCLUDE (e.g. Medical,”,
“     Family, HS Drawings, Nancy Cashman).”,
“  2. Add excluded folder names to EXCLUDE_FOLDERS in your .env”,
“     or directly in build_catalog.py (Phase 2).”,
“  3. Run Phase 2: build_catalog.py to extract EXIF data and”,
“     generate AI tags + scores.”,
]
dest.write_text(”\n”.join(lines) + “\n”, encoding=“utf-8”)
print(f”\n✅ Text report  → {dest}”)

def write_json_report(root: FolderNode, dest: Path) -> None:
def _node(n: FolderNode) -> dict:
return {
“name”:             n.name,
“path”:             n.path,
“total_images”:     n.total_images,
“total_size_bytes”: n.total_size_bytes,
“folders”:          [_node(f) for f in n.folders],
“files”:            [asdict(f) for f in n.files],
}
payload = {
“generated_at”:  datetime.now().isoformat(),
“owncloud_base”: OWNCLOUD_BASE_URL,
“username”:      OWNCLOUD_USERNAME,
“root”:          _node(root),
}
dest.write_text(json.dumps(payload, indent=2), encoding=“utf-8”)
print(f”✅ JSON structure → {dest}”)

