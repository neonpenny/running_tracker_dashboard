# —————————————————————————

# RECURSIVE WALKER

# —————————————————————————

def walk_folder(
session: requests.Session,
dav_base: str,
folder_path: str,
depth: int = 0,
max_depth: Optional[int] = None,
) -> FolderNode:
“””
Recursively walk a WebDAV folder and return a FolderNode tree.

```
Parameters
----------
dav_base    : e.g. "https://owncloud.polloanalytics.com/remote.php/dav/files/pryan"
folder_path : path relative to dav_base, e.g. "/Peter's Photos"
depth       : current recursion depth (used for progress display)
max_depth   : if set, stop recursing deeper than this level
"""
from urllib.parse import quote

# Encode the path for the URL (preserve slashes)
encoded_path = "/".join(quote(segment, safe="") for segment in folder_path.split("/"))
url = dav_base.rstrip("/") + encoded_path

indent = "  " * depth
print(f"{indent}📂 Scanning: {folder_path}")

xml_root = propfind(session, url, depth=1)
entries = parse_responses(xml_root, dav_base)

folder_name = folder_path.rstrip("/").split("/")[-1] or "root"
node = FolderNode(name=folder_name, path=folder_path)

for entry in entries:
    # Skip the folder itself (the first entry in PROPFIND depth=1)
    if entry["path"].rstrip("/") == encoded_path.rstrip("/"):
        continue
    # Also skip if the decoded path matches
    from urllib.parse import unquote
    if unquote(entry["path"]).rstrip("/") == folder_path.rstrip("/"):
        continue

    if entry["is_collection"]:
        # It's a sub-folder
        child_path = folder_path.rstrip("/") + "/" + entry["name"]
        if max_depth is None or depth < max_depth:
            child_node = walk_folder(
                session, dav_base, child_path, depth + 1, max_depth
            )
            node.folders.append(child_node)
            node.total_images    += child_node.total_images
            node.total_size_bytes += child_node.total_size_bytes
        else:
            # Just record the folder name without recursing
            stub = FolderNode(name=entry["name"], path=child_path)
            node.folders.append(stub)
    else:
        # It's a file – only track image files
        ext = Path(entry["name"]).suffix.lower()
        if ext in IMAGE_EXTENSIONS:
            photo = PhotoFile(
                name=entry["name"],
                path=entry["path"],
                size_bytes=entry["size"],
                last_modified=entry["last_modified"],
                extension=ext,
                etag=entry["etag"],
            )
            node.files.append(photo)
            node.total_images    += 1
            node.total_size_bytes += entry["size"]

return node
```

