WEBDAV_NS = “DAV:”

def _tag(name: str) -> str:
return f”{{{WEBDAV_NS}}}{name}”

def propfind(session: requests.Session, url: str, depth: int = 1) -> ET.Element:
“”“Issue a WebDAV PROPFIND request and return the parsed XML root.”””
headers = {
“Depth”: str(depth),
“Content-Type”: “application/xml; charset=utf-8”,
}
body = (
‘<?xml version="1.0" encoding="utf-8"?>’
‘<D:propfind xmlns:D=“DAV:”>’
“  <D:allprop/>”
“</D:propfind>”
)
resp = session.request(“PROPFIND”, url, headers=headers, data=body, timeout=30)

