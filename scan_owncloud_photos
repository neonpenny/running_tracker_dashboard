def main():
parser = argparse.ArgumentParser(
description=“Scan Peter’s ownCloud photo library and output folder structure.”
)
parser.add_argument(”–username”, default=OWNCLOUD_USERNAME)
parser.add_argument(”–password”, default=OWNCLOUD_PASSWORD)
parser.add_argument(
“–start-path”, default=START_PATH,
help=“WebDAV path to scan (default: /Peter’s Photos)”
)
parser.add_argument(
“–max-depth”, type=int, default=None,
help=“Max folder depth to recurse (default: unlimited)”
)
parser.add_argument(
“–output-dir”, default=”.”,
help=“Directory to write output files (default: current directory)”
)
args = parser.parse_args()

```
password = args.password
if not password:
    import getpass
    password = getpass.getpass(
        f"Enter ownCloud password for user '{args.username}': "
    )

# WebDAV endpoint for ownCloud 10.x
dav_base = f"{OWNCLOUD_BASE_URL}/remote.php/dav/files/{args.username}"

session = requests.Session()
session.auth = (args.username, password)
session.verify = True   # set to False if you have SSL cert issues (not recommended)

print(f"\n🔗 Connecting to: {OWNCLOUD_BASE_URL}")
print(f"👤 Username: {args.username}")
print(f"📁 Scanning from: {args.start_path}")
print(f"{'─' * 60}")

root_node = walk_folder(
    session,
    dav_base,
    args.start_path,
    depth=0,
    max_depth=args.max_depth,
)

out_dir = Path(args.output_dir)
out_dir.mkdir(parents=True, exist_ok=True)

write_text_report(root_node, str(out_dir / OUTPUT_TEXT))
write_json_report(root_node, str(out_dir / OUTPUT_JSON))

# Quick console summary
print(f"\n{'=' * 60}")
print(f"SUMMARY")
print(f"{'=' * 60}")
print(f"  Total images found : {root_node.total_images}")
print(f"  Total size         : {_fmt_size(root_node.total_size_bytes)}")
print(f"  Top-level folders  : {len(root_node.folders)}")
print()
print("  Top-level breakdown:")
for f in sorted(root_node.folders, key=lambda x: x.total_images, reverse=True):
    print(f"    {f.name:<40} {f.total_images:>5} images")
print()
print("Next steps:")
print("  1. Review folder_report.txt for the full tree.")
print("  2. Decide which folders to include / exclude.")
print("  3. Run Phase 2: photo metadata + AI tagging pipeline.")
