def parse_responses(xml_root: ET.Element, base_dav_url: str):
“””
Parse a multistatus PROPFIND response.
Returns a list of dicts with keys: href, is_collection, name,
size, last_modified, etag.
“””
results = []
for response in xml_root.iter(_tag(“response”)):
href_el = response.find(_tag(“href”))
if href_el is None:
continue
href = href_el.text or “”

```
    propstat = response.find(_tag("propstat"))
    if propstat is None:
        continue
    prop = propstat.find(_tag("prop"))
    if prop is None:
        continue

    resourcetype = prop.find(_tag("resourcetype"))
    is_collection = resourcetype is not None and resourcetype.find(_tag("collection")) is not None

    size_el = prop.find(_tag("getcontentlength"))
    size = int(size_el.text) if size_el is not None and size_el.text else 0

    lm_el = prop.find(_tag("getlastmodified"))
    last_modified = lm_el.text if lm_el is not None else ""

    etag_el = prop.find(_tag("getetag"))
    etag = (etag_el.text or "").strip('"')

    # Decode percent-encoded href and strip the DAV root prefix
    from urllib.parse import unquote
    path = unquote(href)

    # Extract the display name from the path
    name = path.rstrip("/").split("/")[-1]

    results.append(
        dict(
            href=href,
            path=path,
            name=name,
            is_collection=is_collection,
            size=size,
            last_modified=last_modified,
            etag=etag,
        )
    )
return results
