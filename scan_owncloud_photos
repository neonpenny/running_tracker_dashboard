def *fmt_size(bytes*: int) -> str:
for unit in (“B”, “KB”, “MB”, “GB”):
if bytes_ < 1024:
return f”{bytes_:.1f} {unit}”
bytes_ /= 1024
return f”{bytes_:.1f} TB”

def render_tree(node: FolderNode, indent: int = 0) -> list[str]:
“”“Return lines of a human-readable folder tree.”””
lines = []
pad = “  “ * indent
summary = f”  [{node.total_images} images, {_fmt_size(node.total_size_bytes)}]”
lines.append(f”{pad}📂 {node.name}{summary}”)

```
for f in node.folders:
    lines.extend(render_tree(f, indent + 1))

for img in node.files:
    file_pad = "  " * (indent + 1)
    lines.append(
        f"{file_pad}🖼  {img.name}  ({_fmt_size(img.size_bytes)})  "
        f"[{img.last_modified}]"
    )

return lines
```

def write_text_report(root: FolderNode, path: str) -> None:
lines = [
“=” * 72,
“Peter J Ryan Photography – ownCloud Folder Report”,
f”Generated: {datetime.now().strftime(’%Y-%m-%d %H:%M:%S’)}”,
f”Root path: {root.path}”,
f”Total images found: {root.total_images}”,
f”Total size: {_fmt_size(root.total_size_bytes)}”,
“=” * 72,
“”,
“FOLDER TREE”,
“-” * 72,
]
lines.extend(render_tree(root))
lines += [
“”,
“-” * 72,
“TOP-LEVEL FOLDER SUMMARY”,
“-” * 72,
]
for folder in root.folders:
lines.append(
f”  {folder.name:<40} {folder.total_images:>5} images   “
f”{_fmt_size(folder.total_size_bytes):>10}”
)
lines += [
“”,
“NOTE: Edit scan_owncloud.py to add folders to an EXCLUDE list,”,
“      then re-run to get a filtered version for the website pipeline.”,
]
with open(path, “w”, encoding=“utf-8”) as fh:
fh.write(”\n”.join(lines) + “\n”)
print(f”\n✅ Text report written to: {path}”)

def write_json_report(root: FolderNode, path: str) -> None:
def node_to_dict(n: FolderNode) -> dict:
return {
“name”: n.name,
